# =============================================================================
# TryOn AI — Environment Variables
# Copy this file to .env and fill in the values for local development.
# In production (Railway), set these variables in the Railway dashboard.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Supabase PostgreSQL or any PostgreSQL provider)
# Example: postgresql://user:password@host:5432/dbname?sslmode=require
# -----------------------------------------------------------------------------
DATABASE_URL=

# -----------------------------------------------------------------------------
# Shopify App Credentials
# From your Shopify Partner Dashboard > Apps > [your app] > API credentials
# -----------------------------------------------------------------------------
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Public URL of this app (Railway URL in prod, Cloudflare tunnel URL in dev)
# Example: https://your-app.up.railway.app
SHOPIFY_APP_URL=

# Shopify OAuth scopes required by the app
SCOPES=write_products,read_products

# -----------------------------------------------------------------------------
# Stripe Billing
# From your Stripe Dashboard > Developers > API keys
# -----------------------------------------------------------------------------
# Secret key — use sk_test_... for dev, sk_live_... for prod
STRIPE_SECRET_KEY=

# Webhook signing secret (whsec_...) from Stripe Dashboard > Webhooks
# Endpoint to register: https://your-app.up.railway.app/api/stripe/webhook
# Events: checkout.session.completed, customer.subscription.updated,
#         customer.subscription.deleted, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs for each plan (price_... from Stripe Dashboard > Products)
# Plans are products-first: the primary value is the number of products with try-on.
# Try-on counts are fair-use limits that reset monthly.
#
#   Starter  $19/mo — 3 products,  up to 300 try-ons/mo
#   Premium  $49/mo — 8 products,  up to 800 try-ons/mo
#   Pro      $89/mo — 20 products, up to 2000 try-ons/mo  (highlighted / most popular)
#   Ultimate $179/mo — unlimited products, up to 5000 try-ons/mo
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ULTIMATE=

# Stripe Price ID for the extra products add-on (+2 products, +150 try-ons — $15/mo)
STRIPE_PRICE_ADDON=

# -----------------------------------------------------------------------------
# Replicate AI (IDM-VTON virtual try-on)
# From https://replicate.com/account/api-tokens
# -----------------------------------------------------------------------------
REPLICATE_API_TOKEN=

# Pinned model version ID (recommended for production).
# Find it at https://replicate.com/cuuupid/idm-vton/versions
# When set, the app skips the version-resolution API call and uses this version
# directly — faster, cheaper, and immune to unexpected model updates.
# Leave empty to always resolve the latest version automatically.
REPLICATE_MODEL_VERSION=

# -----------------------------------------------------------------------------
# Mock mode
# Set to "true" to return a placeholder image instead of calling Replicate.
# Useful for local development without a Replicate token.
# -----------------------------------------------------------------------------
USE_MOCK=false

# -----------------------------------------------------------------------------
# Migrations
# Set to "true" on the primary instance to run `prisma migrate deploy` on
# startup. Set to "false" on additional (worker) instances to avoid conflicts.
# -----------------------------------------------------------------------------
RUN_MIGRATIONS=true

# -----------------------------------------------------------------------------
# Nano Banana (optional alternative AI backend)
# Only needed if you use the NanoBanana service instead of Replicate.
# -----------------------------------------------------------------------------
# NANO_ENDPOINT_URL=
# NANO_API_KEY=
# NANO_MODEL=

# -----------------------------------------------------------------------------
# Node environment (set automatically by Railway/Docker)
# -----------------------------------------------------------------------------
NODE_ENV=production
